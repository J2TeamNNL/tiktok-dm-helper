{
  "manifest_version": 3,
  "name": "TikTok DM Helper",
  "description": "Bộ tiện ích client-side cho tin nhắn TikTok web. Tính năng đầu tiên: nhảy tới video gần nhất bạn đã thả reaction.",
  "version": "0.1.0",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://www.tiktok.com/*"],
      "js": [
        "src/dom-selectors.js",
        "src/finder.js",
        "src/ui-panel.js",
        "src/content-script.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
